# Playwright 配置
HEADLESS=true                       # 生产环境必须为 true
PROXY=                               # 代理地址，如 http://127.0.0.1:7890
USER_DATA_DIR=                      # 浏览器用户数据目录

# ASR 配置
ASR_ENGINE=sensevoice               # 语音识别引擎: sensevoice / whisper
WHISPER_MODEL=medium                # Whisper 模型: tiny/base/small/medium/large
WHISPER_DEVICE=cpu                  # cpu / cuda

# SenseVoice 配置
SENSEVOICE_MODEL=iic/SenseVoiceSmall-onnx
SENSEVOICE_DEVICE=cpu               # cpu / cuda

# AI 分析器配置
LLM_PROVIDER=paddleocr              # paddleocr / openai / dashscope

# PaddleOCR-VL 配置
PADDLEOCR_MODEL=PaddleOCR/PaddleOCR-VL-1.5
PADDLEOCR_DEVICE=cpu                # cpu / cuda

# OpenAI 配置（LLM_PROVIDER=openai 时使用）
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# 通义千问配置（LLM_PROVIDER=dashscope 时使用）
# DASHSCOPE_API_KEY=xxx

# 智谱AI配置（用于AI创作功能）
ZHIPU_API_KEY=                      # 你的智谱AI API Key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=GLM-4.1V-Thinking-Flash

# API 配置
API_HOST=0.0.0.0
API_PORT=18765
DEBUG=false                          # 生产环境必须为 false

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./data/douyin.db